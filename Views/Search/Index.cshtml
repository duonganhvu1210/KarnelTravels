@model IEnumerable<KarnelTravels.Models.Tour>
@{
    ViewData["Title"] = "Tìm kiếm";
    var query = ViewData["Query"] as string;
    var type = ViewData["Type"] as string;
    var spots = ViewData["Spots"] as IEnumerable<KarnelTravels.Models.TouristSpot>;
    var hotels = ViewData["Hotels"] as IEnumerable<KarnelTravels.Models.Hotel>;
    var tours = ViewData["Tours"] as IEnumerable<KarnelTravels.Models.Tour>;
    var restaurants = ViewData["Restaurants"] as IEnumerable<KarnelTravels.Models.Restaurant>;
    var resorts = ViewData["Resorts"] as IEnumerable<KarnelTravels.Models.Resort>;
    var transports = ViewData["Transports"] as IEnumerable<KarnelTravels.Models.Transport>;
}

<section class="py-5 bg-light">
    <div class="container">
        <h1 class="text-center mb-4">Tìm kiếm</h1>
        
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <form asp-action="Index" method="get" class="row g-3">
                    <div class="col-md-8">
                        <input type="text" name="query" class="form-control form-control-lg" placeholder="Nhập từ khóa tìm kiếm..." value="@query">
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary btn-lg w-100"><i class="fas fa-search"></i> Tìm kiếm</button>
                    </div>
                </form>
            </div>
        </div>

        @if(!string.IsNullOrEmpty(query) || !string.IsNullOrEmpty(type))
        {
            <ul class="nav nav-pills mb-4" id="searchTabs" role="tablist">
                <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#all">Tất cả</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#spots">Điểm du lịch</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tours">Tour</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#hotels">Khách sạn</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#restaurants">Nhà hàng</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#resorts">Resort</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#transports">Vận chuyển</button></li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="all">
                    @if(spots.Any() || hotels.Any() || tours.Any() || restaurants.Any() || resorts.Any() || transports.Any())
                    {
                        <div class="row g-4">
                            @foreach(var spot in spots.Take(3))
                            {
                                <div class="col-md-4">
                                    <div class="card h-100 border-0 shadow-sm">
                                        <div class="card-body">
                                            <h5>@spot.Name</h5>
                                            <p class="text-muted">@spot.Region</p>
                                            <a asp-controller="TouristSpot" asp-action="Details" asp-route-id="@spot.SpotId" class="btn btn-sm btn-primary">Xem chi tiết</a>
                                        </div>
                                    </div>
                                </div>
                            }
                            @foreach(var tour in tours.Take(3))
                            {
                                <div class="col-md-4">
                                    <div class="card h-100 border-0 shadow-sm">
                                        <div class="card-body">
                                            <h5>@tour.Name</h5>
                                            <p class="text-primary fw-bold">@tour.Price.ToString("N0") VNĐ</p>
                                            <a asp-controller="Tour" asp-action="Details" asp-route-id="@tour.TourId" class="btn btn-sm btn-primary">Xem chi tiết</a>
                                        </div>
                                    </div>
                                </div>
                            }
                            @foreach(var hotel in hotels.Take(3))
                            {
                                <div class="col-md-4">
                                    <div class="card h-100 border-0 shadow-sm">
                                        <div class="card-body">
                                            <h5>@hotel.Name</h5>
                                            <p class="text-muted">@hotel.City - @hotel.StarRating sao</p>
                                            <a asp-controller="Hotel" asp-action="Details" asp-route-id="@hotel.HotelId" class="btn btn-sm btn-primary">Xem chi tiết</a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">Không tìm thấy kết quả nào!</div>
                    }
                </div>
            </div>
        }
    </div>
</section>
