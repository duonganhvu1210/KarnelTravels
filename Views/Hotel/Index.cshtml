@model IEnumerable<KarnelTravels.Models.Hotel>
@{
    ViewData["Title"] = "Khách sạn";
}

<section class="py-5 bg-light">
    <div class="container">
        <h1 class="text-center mb-4">Khách sạn</h1>
        
        <div class="row g-4">
            @foreach(var hotel in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-img-top bg-secondary" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-hotel fa-3x text-white"></i>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@hotel.Name</h5>
                            <p class="text-muted">
                                @for(int i = 0; i < hotel.StarRating; i++)
                                {
                                    <i class="fas fa-star text-warning"></i>
                                }
                            </p>
                            <p class="text-muted"><i class="fas fa-map-marker-alt"></i> @hotel.City</p>
                            <p class="card-text text-truncate">@hotel.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-primary fw-bold">@hotel.MinPrice?.ToString("N0") - @hotel.MaxPrice?.ToString("N0") VNĐ</span>
                                <a asp-controller="Hotel" asp-action="Details" asp-route-id="@hotel.HotelId" class="btn btn-primary">Xem</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
