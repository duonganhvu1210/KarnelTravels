@{
    Layout = "_AdminLayout";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Karnel Travels Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <div class="d-flex" id="wrapper">
        <div class="bg-dark text-white p-3" id="sidebar-wrapper" style="min-height: 100vh;">
            <div class="sidebar-heading py-4">
                <h4><i class="fas fa-plane"></i> Admin</h4>
            </div>
            <div class="list-group list-group-flush">
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="ManageSpots">
                    <i class="fas fa-map-marker-alt"></i> Điểm du lịch
                </a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="ManageHotels">
                    <i class="fas fa-hotel"></i> Khách sạn
                </a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="ManageTours">
                    <i class="fas fa-suitcase"></i> Tour du lịch
                </a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="ManageBookings">
                    <i class="fas fa-calendar-check"></i> Đơn đặt
                </a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="ManageContacts">
                    <i class="fas fa-envelope"></i> Liên hệ
                </a>
                <a class="list-group-item list-group-item-action bg-dark text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="ManagePromotions">
                    <i class="fas fa-tags"></i> Khuyến mãi
                </a>
            </div>
        </div>
        
        <div id="page-content-wrapper" class="flex-grow-1">
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom">
                <div class="container-fluid">
                    <button class="btn btn-primary" id="menu-toggle">Toggle Menu</button>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mt-2 mt-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index" target="_blank">
                                    <i class="fas fa-external-link-alt"></i> Xem website
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle"></i> Admin
                                </a>
                                <div class="dropdown-menu dropdown-menu-end">
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid mt-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
