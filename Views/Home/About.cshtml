@{
    ViewData["Title"] = "Giới thiệu";
}

<section class="py-5">
    <div class="container">
        <h1 class="text-center mb-5">Giới thiệu về Karnel Travels</h1>
        
        <div class="row mb-5">
            <div class="col-lg-6">
                <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600" class="img-fluid rounded shadow" alt="Karnel Travels">
            </div>
            <div class="col-lg-6">
                <h3 class="mb-3">Chúng tôi là ai?</h3>
                <p class="lead">Karnel Travels là công ty du lịch và lữ hành hàng đầu Việt Nam, chuyên cung cấp các dịch vụ du lịch chất lượng cao.</p>
                <p>Với nhiều năm kinh nghiệm trong ngành, chúng tôi tự hào mang đến cho khách hàng những trải nghiệm du lịch tuyệt vời nhất tại Việt Nam và khu vực.</p>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-md-12">
                <h3 class="mb-4">Tầm nhìn và sứ mệnh</h3>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h5><i class="fas fa-eye text-primary"></i> Tầm nhìn</h5>
                                <p>Trở thành công ty du lịch hàng đầu, mang đến những trải nghiệm du lịch đáng nhớ cho mọi khách hàng.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h5><i class="fas fa-bullseye text-primary"></i> Sứ mệnh</h5>
                                <p>Cam kết cung cấp dịch vụ chất lượng, an toàn và tiện lợi với giá cả hợp lý nhất.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-md-12">
                <h3 class="mb-4">Dịch vụ của chúng tôi</h3>
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <div class="text-center p-4 bg-light rounded">
                            <i class="fas fa-bus fa-2x text-primary mb-3"></i>
                            <h5>Vận chuyển</h5>
                            <p class="small">Xe khách, limousine, máy bay, tàu hỏa</p>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="text-center p-4 bg-light rounded">
                            <i class="fas fa-hotel fa-2x text-primary mb-3"></i>
                            <h5>Khách sạn</h5>
                            <p class="small">Đặt phòng khách sạn cao cấp</p>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="text-center p-4 bg-light rounded">
                            <i class="fas fa-map-marked-alt fa-2x text-primary mb-3"></i>
                            <h5>Tour trọn gói</h5>
                            <p class="small">Các gói tour du lịch trong nước</p>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="text-center p-4 bg-light rounded">
                            <i class="fas fa-umbrella-beach fa-2x text-primary mb-3"></i>
                            <h5>Resort</h5>
                            <p class="small">Nghỉ dưỡng tại các resort cao cấp</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center">
            <h3 class="mb-4">Điểm đến phổ biến</h3>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center">
                            <i class="fas fa-water fa-3x text-info mb-3"></i>
                            <h5>Vịnh Hạ Long</h5>
                            <p class="text-muted">Di sản thiên nhiên thế giới</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center">
                            <i class="fas fa-city fa-3x text-warning mb-3"></i>
                            <h5>Đà Nẵng</h5>
                            <p class="text-muted">Thành phố đáng sống nhất</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center">
                            <i class="fas fa-plane-arrival fa-3x text-success mb-3"></i>
                            <h5>Phú Quốc</h5>
                            <p class="text-muted">Đảo ngọc xanh</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
