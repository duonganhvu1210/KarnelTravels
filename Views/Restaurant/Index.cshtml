@model IEnumerable<KarnelTravels.Models.Restaurant>
@{
    ViewData["Title"] = "Nhà hàng";
}

<section class="py-5 bg-light">
    <div class="container">
        <h1 class="text-center mb-4">Nhà hàng</h1>
        
        <div class="row g-4">
            @foreach(var restaurant in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-img-top bg-secondary" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-utensils fa-3x text-white"></i>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@restaurant.Name</h5>
                            <p class="text-muted">@restaurant.CuisineType - @restaurant.PriceRange</p>
                            <p class="text-muted"><i class="fas fa-map-marker-alt"></i> @restaurant.City</p>
                            <p class="card-text text-truncate">@restaurant.Description</p>
                            <a asp-controller="Restaurant" asp-action="Details" asp-route-id="@restaurant.RestaurantId" class="btn btn-primary">Xem</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
