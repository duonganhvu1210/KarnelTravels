@model IEnumerable<KarnelTravels.Models.Tour>
@{
    ViewData["Title"] = "Tour du lịch";
}

<section class="py-5 bg-light">
    <div class="container">
        <h1 class="text-center mb-4">Tour du lịch</h1>
        
        <div class="row g-4">
            @foreach(var tour in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-img-top bg-secondary" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-map-marked-alt fa-3x text-white"></i>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@tour.Name</h5>
                            <p class="text-muted">@tour.DurationDays ngày @((tour.DurationDays - 1)) đêm</p>
                            <p class="text-muted"><i class="fas fa-map-marker-alt"></i> @tour.Destination</p>
                            <p class="card-text text-truncate">@tour.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-primary fw-bold fs-5">@tour.Price.ToString("N0") VNĐ</span>
                                <a asp-controller="Tour" asp-action="Details" asp-route-id="@tour.TourId" class="btn btn-primary">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
