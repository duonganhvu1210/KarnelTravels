@model KarnelTravels.Models.Contact
@{
    ViewData["Title"] = "Liên hệ";
}

<section class="py-5">
    <div class="container">
        <h1 class="text-center mb-5">Liên hệ với chúng tôi</h1>
        
        @if(TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="mb-4">Gửi tin nhắn cho chúng tôi</h3>
                        <form asp-action="Contact" method="post">
                            <div class="mb-3">
                                <label class="form-label">Họ và tên *</label>
                                <input asp-for="Name" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email *</label>
                                <input asp-for="Email" type="email" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Điện thoại</label>
                                <input asp-for="Phone" class="form-control">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Dịch vụ quan tâm</label>
                                <select asp-for="ServiceInterest" class="form-select">
                                    <option value="">Chọn dịch vụ</option>
                                    <option value="Tour">Tour du lịch</option>
                                    <option value="Hotel">Khách sạn</option>
                                    <option value="Resort">Resort</option>
                                    <option value="Transport">Vận chuyển</option>
                                    <option value="Other">Khác</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Nội dung *</label>
                                <textarea asp-for="Message" class="form-control" rows="5" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg">Gửi tin nhắn</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h3 class="mb-4">Thông tin liên hệ</h3>
                        <div class="mb-3">
                            <p><i class="fas fa-map-marker-alt text-primary me-2"></i> Hà Nội, Việt Nam</p>
                            <p><i class="fas fa-phone text-primary me-2"></i> +84 123 456 789</p>
                            <p><i class="fas fa-envelope text-primary me-2"></i> info@karneltravels.com</p>
                            <p><i class="fas fa-clock text-primary me-2"></i> Thứ 2 - Thứ 7: 8:00 - 18:00</p>
                        </div>
                    </div>
                </div>
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4 text-center">
                        <h5>Kết nối với chúng tôi</h5>
                        <div class="mt-3">
                            <a href="#" class="btn btn-outline-primary me-2"><i class="fab fa-facebook"></i> Facebook</a>
                            <a href="#" class="btn btn-outline-danger me-2"><i class="fab fa-youtube"></i> YouTube</a>
                            <a href="#" class="btn btn-outline-info"><i class="fab fa-instagram"></i> Instagram</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
