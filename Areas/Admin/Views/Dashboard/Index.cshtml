@model KarnelTravels.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<!-- F161-F164: 4 Small Boxes - Thống kê tổng quan -->
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>@Model.TotalDestinations</h3>
                <p>Điểm du lịch (F161)</p>
            </div>
            <div class="icon">
                <i class="fas fa-map-marker-alt"></i>
            </div>
            <a asp-action="ManageSpots" class="small-box-footer">Xem chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>@Model.TotalHotels</h3>
                <p>Khách sạn (F162)</p>
            </div>
            <div class="icon">
                <i class="fas fa-hotel"></i>
            </div>
            <a asp-action="ManageHotels" class="small-box-footer">Xem chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>@Model.TotalRestaurants</h3>
                <p>Nhà hàng (F163)</p>
            </div>
            <div class="icon">
                <i class="fas fa-utensils"></i>
            </div>
            <a href="#" class="small-box-footer">Xem chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-danger">
            <div class="inner">
                <h3>@Model.TotalResorts</h3>
                <p>Resort (F164)</p>
            </div>
            <div class="icon">
                <i class="fas fa-swimming-pool"></i>
            </div>
            <a href="#" class="small-box-footer">Xem chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>

<!-- F165-F166: Thống kê đơn hàng và doanh thu -->
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="small-box bg-secondary">
            <div class="inner">
                <h3>@Model.TodayOrdersCount</h3>
                <p>Đơn hàng hôm nay (F165)</p>
            </div>
            <div class="icon">
                <i class="fas fa-calendar-day"></i>
            </div>
            <a asp-action="ManageBookings" class="small-box-footer">Xem chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-primary">
            <div class="inner">
                <h3>@Model.MonthlyRevenue.ToString("N0") VNĐ</h3>
                <p>Doanh thu tháng này (F166)</p>
            </div>
            <div class="icon">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <span class="small-box-footer">&nbsp;</span>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-dark">
            <div class="inner">
                <h3>@Model.TotalBookings</h3>
                <p>Tổng đơn hàng (F170)</p>
            </div>
            <div class="icon">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <a asp-action="ManageBookings" class="small-box-footer">Xem chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-teal">
            <div class="inner">
                <h3>@Model.TotalRevenue.ToString("N0") VNĐ</h3>
                <p>Tổng doanh thu</p>
            </div>
            <div class="icon">
                <i class="fas fa-chart-line"></i>
            </div>
            <span class="small-box-footer">&nbsp;</span>
        </div>
    </div>
</div>

<!-- F168: Biểu đồ doanh thu 12 tháng -->
<div class="row">
    <div class="col-md-12">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Doanh thu 12 tháng gần đây (F168)</h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="chart">
                    <canvas id="revenueChart" style="min-height: 350px; height: 350px; max-height: 350px; max-width: 100%;"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- F167 & F169: Bảng đơn hàng gần đây và Liên hệ chưa đọc -->
<div class="row">
    <!-- F167: Danh sách đơn hàng gần đây -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Đơn hàng gần đây (F167)</h3>
                <div class="card-tools">
                    <a asp-action="ManageBookings" class="btn btn-sm btn-primary">Xem tất cả</a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Tour</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model.RecentBookings)
                        {
                            <tr>
                                <td>#@booking.BookingId</td>
                                <td>@booking.CustomerName</td>
                                <td>@booking.Tour?.Name</td>
                                <td>@booking.BookingDate.ToString("dd/MM/yyyy")</td>
                                <td>@booking.TotalAmount.ToString("N0") VNĐ</td>
                                <td>
                                    @{
                                        var badgeClass = booking.Status switch
                                        {
                                            "Pending" => "badge-warning",
                                            "Confirmed" => "badge-info",
                                            "Paid" or "Completed" => "badge-success",
                                            "Cancelled" => "badge-danger",
                                            _ => "badge-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@booking.Status</span>
                                </td>
                                <td>
                                    <a asp-action="ManageBookings" asp-route-id="@booking.BookingId" class="btn btn-sm btn-info">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- F169: Liên hệ chưa đọc -->
    <div class="col-md-4">
        <div class="card card-warning">
            <div class="card-header">
                <h3 class="card-title">Liên hệ chưa đọc (F169)</h3>
                <div class="card-tools">
                    <a asp-action="ManageContacts" class="btn btn-sm btn-warning">Xem tất cả</a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.UnreadContacts.Any())
                {
                    <ul class="products-list product-list-in-card">
                        @foreach (var contact in Model.UnreadContacts)
                        {
                            <li class="item">
                                <div class="product-info">
                                    <a href="javascript:void(0)" class="product-title">
                                        @contact.Name
                                        <span class="badge badge-warning float-right">Mới</span>
                                    </a>
                                    <span class="product-description">
                                        @(contact.Title ?? "Liên hệ mới") - @contact.CreatedAt.ToString("dd/MM/yyyy")
                                    </span>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center p-3">
                        <p class="text-muted">Không có liên hệ mới</p>
                    </div>
                }
            </div>
            <div class="card-footer text-center">
                <a asp-action="ManageContacts" class="uppercase">Xem tất cả liên hệ</a>
            </div>
        </div>
    </div>
</div>

